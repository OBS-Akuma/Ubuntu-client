{
  "name": "ubuntu-client",
  "version": "1.0.0",
  "description": "The Electron client for Kirka.io that i never made but always wanted to.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Akuma",
  "license": "ISC",
  "dependencies": {
    "discord-rpc": "^4.0.1"
  },
  "devDependencies": {
    "electron": "^10.4.7",
    "electron-builder": "^23.0.2"
  },
  "build": {
    "appId": "xyz.ubuntuclient",
    "productName": "Ubuntu Client",
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,changelog.md}"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}